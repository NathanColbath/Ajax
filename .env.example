# Copy to .env and fill in secrets (Compose loads .env automatically).
# Do not commit .env.

# Public URL of the SPA (must match Auth0 Allowed Callback / Logout / Web Origins).
# Docker Compose serves the app on this host:port (default port 80).
PUBLIC_ORIGIN=http://localhost
HTTP_PORT=80

# Production (docker-compose.prod.yml / scripts/deploy-vps.sh)
# IMAGE_TAG=1.2.0
# GHCR_IMAGE_PREFIX=nathancolbath/ajax

# Auth0 (optional overrides — defaults match local SPA config)
# AUTH0_DOMAIN=dev-82ln3zs1yykao3qo.us.auth0.com
# AUTH0_AUDIENCE=https://game-library-api

# Optional enrichment / metadata keys
HASHEOUS_API_KEY=
IGDB_CLIENT_ID=
IGDB_CLIENT_SECRET=
DEEPSEEK_API_KEY=
