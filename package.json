{
  "name": "game-library",
  "version": "0.2.2",
  "scripts": {
    "ng": "ng",
    "start": "ng serve --port 4200 --proxy-config proxy.conf.json",
    "api": "dotnet run --project api/GameLibrary.Api --launch-profile http",
    "build": "ng build",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "branch": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/new-branch.ps1",
    "cut-version": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/cut-version.ps1",
    "cut-version:patch": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/cut-version.ps1 -Bump patch",
    "cut-version:minor": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/cut-version.ps1 -Bump minor",
    "cut-version:major": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/cut-version.ps1 -Bump major"
  },
  "prettier": {
    "printWidth": 100,
    "singleQuote": true,
    "overrides": [
      {
        "files": "*.html",
        "options": {
          "parser": "angular"
        }
      }
    ]
  },
  "private": true,
  "dependencies": {
    "@angular/animations": "^20.3.26",
    "@angular/cdk": "^20.2.14",
    "@angular/common": "^20.3.0",
    "@angular/compiler": "^20.3.0",
    "@angular/core": "^20.3.0",
    "@angular/forms": "^20.3.0",
    "@angular/material": "^20.2.14",
    "@angular/platform-browser": "^20.3.0",
    "@angular/router": "^20.3.0",
    "@auth0/auth0-angular": "^2.10.1",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0",
    "zone.js": "~0.15.0"
  },
  "devDependencies": {
    "@angular/build": "^20.3.9",
    "@angular/cli": "^20.3.9",
    "@angular/compiler-cli": "^20.3.0",
    "@types/jasmine": "~5.1.0",
    "jasmine-core": "~5.9.0",
    "karma": "~6.4.0",
    "karma-chrome-launcher": "~3.2.0",
    "karma-coverage": "~2.2.0",
    "karma-jasmine": "~5.1.0",
    "karma-jasmine-html-reporter": "~2.1.0",
    "typescript": "~5.9.2"
  }
}
